{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/auth/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/auth/{**catch-all}" }
        ]
      },
      "users-route": {
        "ClusterId": "users-cluster",
        "Match": { "Path": "/users/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/users/{**catch-all}" }
        ]
      },
      "portfolio-route": {
        "ClusterId": "holdings-cluster",
        "Match": { "Path": "/portfolio/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v1/portfolio/{**catch-all}" }
        ]
      },
      "holdings-route": {
        "ClusterId": "holdings-cluster",
        "Match": { "Path": "/holdings/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v1/holdings/{**catch-all}" }
        ]
      },
      "prices-route": {
        "ClusterId": "marketdata-cluster",
        "Match": { "Path": "/prices/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/v1/prices/{**catch-all}" }
        ]
      },
      "transactions-route": {
        "ClusterId": "transactions-cluster",
        "Match": { "Path": "/transactions/{**catch-all}" },
        "Transforms": [
          { "PathPattern": "/api/transaction/{**catch-all}" }
        ]
      }
    },
    "Clusters": {
      "users-cluster": {
        "Destinations": {
          "primary": { "Address": "http://users-service:8080" }
        }
      },
      "holdings-cluster": {
        "Destinations": {
          "primary": { "Address": "http://holdings-service:8080" }
        }
      },
      "marketdata-cluster": {
        "Destinations": {
          "primary": { "Address": "http://marketdata-service:8080" }
        }
      },
      "transactions-cluster": {
        "Destinations": {
          "primary": { "Address": "http://transactions-service:8080" }
        }
      }
    }
  }
}
